# =====
# Etherion — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env or any file containing real credentials.
# =====

# --- Core ---------------------------------------------------------------

ENVIRONMENT=dev
PRIMARY_DOMAIN=localhost                  # Your public domain (e.g. etherion.example.com)
AUTH_BASE_URL=http://localhost:8000       # Public URL of the API server

# --- Database -----------------------------------------------------------

# For local/compose dev:
POSTGRES_USER=etherion
POSTGRES_PASSWORD=etherion
POSTGRES_DB=etherion_dev
DATABASE_URL=postgresql+psycopg2://etherion:etherion@db:5432/etherion_dev

# --- Redis --------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- API / Server -------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8000
PORT=8080

# --- Security -----------------------------------------------------------

JWT_SECRET_KEY=replace_me_with_a_long_random_string
JWT_ALGORITHM=HS256
SECRET_KEY=replace_me_with_another_long_random_string

# =====
# LOGIN OAuth (used for signing in to the Etherion platform itself)
# Register YOUR OWN OAuth apps — Etherion stores no central credentials.
# =====

# Amazon Bedrock (primary default)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
# AWS_SESSION_TOKEN=  # Required for SSO/temporary credentials

# Google Gemini API (via API key, not Vertex)
GEMINI_API_KEY=

# OpenRouter (unified API for 200+ models)
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=https://etherion.ai
OPENROUTER_APP_TITLE=Etherion

# OpenAI (direct)
# OPENAI_API_KEY=

# Anthropic (direct, not via Bedrock)
# ANTHROPIC_API_KEY=

# Web search
EXA_API_KEY=

# ── Model Selection ───────────────────────────────────────────
# Controls which provider and model tier powers each role.
# Format: provider name (bedrock, openai, gemini, anthropic,
# openrouter, vertex)
# Model tiers: fast, default, smart (maps to provider-specific models)
ORCHESTRATOR_PROVIDER=bedrock
ORCHESTRATOR_MODEL=fast
SPECIALIST_PROVIDER=bedrock
SPECIALIST_MODEL=fast
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-004

# ── Knowledge Base ─────────────────────────────────────────────
KB_VECTOR_BACKEND=pgvector
KB_EMBEDDING_DIM=1536
SKIP_EMBEDDING=true

# ── Secrets Backend ────────────────────────────────────────────
SECRETS_BACKEND=local
USE_LOCAL_SECRETS=true
# SECRETS_BACKEND=vault
# VAULT_ADDR=http://localhost:8200
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=
# VAULT_MOUNT=secret

# ── OAuth ──────────────────────────────────────────────────────
# You MUST register your own OAuth apps with each provider.
# Etherion does not provide pre-registered apps.
# See Docs/etherion_docs/authentication/oauth-flow.md for setup guides.

# Google OAuth (for Google Login + Gmail, Drive, Calendar, Docs, Sheets, Slides, Forms, Tasks, Chat)
# Create at: https://console.cloud.google.com/apis/credentials
# Required scopes: openid, email, profile, plus Google Workspace scopes as needed
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# Legacy fallbacks (same values):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (for GitHub Login)
# Create at: https://github.com/settings/developers
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Microsoft OAuth (for Microsoft Login + MS365)
# Create at: https://portal.azure.com/ > App registrations
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# OAUTH_MICROSOFT_TENANT=consumers  # or your tenant ID

# Slack OAuth (for Slack tools)
# Create at: https://api.slack.com/apps
SLACK_USER_OAUTH_CLIENT_ID=
SLACK_USER_OAUTH_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Jira OAuth (for Jira tools)
# Create at: https://developer.atlassian.com/console/myapps/
OAUTH_JIRA_CLIENT_ID=
OAUTH_JIRA_CLIENT_SECRET=

# Notion OAuth (for Notion tools)
# Create at: https://www.notion.com/my-integrations
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# HubSpot OAuth (for HubSpot tools)
# Create at: https://developers.hubspot.com/
HUBSPOT_OAUTH_CLIENT_ID=
HUBSPOT_OAUTH_CLIENT_SECRET=

# Shopify OAuth (for Shopify tools)
# Create at: https://partners.shopify.com/ > Apps
SHOPIFY_OAUTH_CLIENT_ID=
SHOPIFY_OAUTH_CLIENT_SECRET=

# LinkedIn OAuth (for LinkedIn tools)
OAUTH_LINKEDIN_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_SECRET=

# Salesforce OAuth (for Salesforce tools)
OAUTH_SALESFORCE_CLIENT_ID=
OAUTH_SALESFORCE_CLIENT_SECRET=

# Instagram OAuth (for Instagram tools)
OAUTH_INSTAGRAM_CLIENT_ID=
OAUTH_INSTAGRAM_CLIENT_SECRET=

# Twitter/X OAuth (for Twitter tools)
OAUTH_TWITTER_CLIENT_ID=
OAUTH_TWITTER_CLIENT_SECRET=

# Reddit OAuth (for Reddit tools)
OAUTH_REDDIT_CLIENT_ID=
OAUTH_REDDIT_CLIENT_SECRET=

# OAuth base URL (used for callback redirects)
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
AUTH_BASE_URL=http://localhost:8080

# =====
# SILO OAuth (used by AI agents to READ third-party data on behalf of users)
# Each operator registers their own app with each provider below.
# Users connect their own accounts through the TUI → OAuth tab.
# =====

# ── Google (Drive + Gmail) ──────────────────────────────────────────────────
# Register at: console.cloud.google.com/auth/clients
# App type: Web application
# Redirect URI: {AUTH_BASE_URL}/oauth/silo/google/callback
# Scopes: drive.readonly, gmail.readonly, userinfo.email, userinfo.profile
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# ── Slack ───────────────────────────────────────────────────────────────────
# Register at: api.slack.com/apps → Create New App → From scratch
# OAuth & Permissions → Redirect URLs: {AUTH_BASE_URL}/oauth/silo/slack/callback
# User Token Scopes: channels:read, channels:history, files:read, users:read
SLACK_USER_OAUTH_CLIENT_ID=
SLACK_USER_OAUTH_CLIENT_SECRET=

# ── Microsoft 365 (Outlook + OneDrive) ─────────────────────────────────────
# Register at: entra.microsoft.com → App registrations → New registration
# Redirect URI (Web): {AUTH_BASE_URL}/oauth/silo/microsoft/callback
# API Permissions: Mail.Read, Files.Read, User.Read, offline_access
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# ── Jira / Atlassian ────────────────────────────────────────────────────────
# OAuth App at: developer.atlassian.com/console/myapps → Create → OAuth 2.0 integration
# Callback URL: {AUTH_BASE_URL}/oauth/silo/jira/callback
# Permissions: read:jira-user, read:jira-work, offline_access
# (Users can also use an API token — entered directly in TUI without env vars)
OAUTH_JIRA_CLIENT_ID=
OAUTH_JIRA_CLIENT_SECRET=

# ── HubSpot ─────────────────────────────────────────────────────────────────
# Register at: app.hubspot.com → Settings → Integrations → Private Apps
# (Users can also create their own Private App token — entered directly in TUI)
# For OAuth app: developers.hubspot.com/docs/apps
# Redirect URI: {AUTH_BASE_URL}/oauth/silo/hubspot/callback
# Scopes: crm.objects.contacts.read, crm.objects.companies.read, oauth
HUBSPOT_OAUTH_CLIENT_ID=
HUBSPOT_OAUTH_CLIENT_SECRET=

# ── Notion ───────────────────────────────────────────────────────────────────
# Public OAuth Integration at: notion.so/profile/integrations → New Integration → Public
# Redirect URI: {AUTH_BASE_URL}/oauth/silo/notion/callback
# (Users can also use an Internal Integration token — entered directly in TUI)
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# ── Shopify ─────────────────────────────────────────────────────────────────
# Partner App: partners.shopify.com → Apps → Create app
# Custom App: {store}.myshopify.com/admin/settings/apps → Develop apps
# Allowed redirect URL: {AUTH_BASE_URL}/oauth/silo/shopify/callback
# Scopes: read_products, read_customers, read_orders
SHOPIFY_OAUTH_CLIENT_ID=
SHOPIFY_OAUTH_CLIENT_SECRET=

# ── GitHub (token-based — no OAuth app needed) ──────────────────────────────
# Users generate their own Personal Access Token in the TUI → OAuth tab.
# Scopes: repo, read:org, read:user
# No env vars needed here.

# ── Linear (token-based — no OAuth app needed) ──────────────────────────────
# Users generate their own API Key in the TUI → OAuth tab.
# No env vars needed here.

# =====
# LLM Providers (set at least one)
# =====

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# =====
# Storage (default: local filesystem for dev, minio for production)
# =====

STORAGE_BACKEND=local          # local | minio | gcs
STORAGE_LOCAL_ROOT=/var/lib/etherion/storage

# MinIO (set when STORAGE_BACKEND=minio)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=etherion-artifacts

# =====
# Vault (optional — set when SECRETS_BACKEND=vault)
# =====

SECRETS_BACKEND=env            # env | vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=                   # dev mode only; use AppRole in production
VAULT_ROLE_ID=
VAULT_SECRET_ID=
