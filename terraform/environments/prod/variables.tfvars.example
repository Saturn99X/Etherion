# terraform/environments/prod/variables.tfvars.example
# Copy this file to variables.tfvars and fill in your actual values

# Project Configuration
project_id    = "your-actual-prod-project-id"
region        = "us-central1"
image_url     = "us-central1-docker.pkg.dev/your-actual-prod-project-id/etherion-ai/etherion-ai-prod:latest"

# Database Configuration
db_password   = "your-actual-prod-db-password"

# Secret Manager Environment Variables
secret_env_vars = {
  DATABASE_URL = {
    name = "etherion-db-url-prod"
    key  = "latest"
  }
  SECRET_KEY = {
    name = "etherion-secret-key-prod"
    key  = "latest"
  }
  JWT_SECRET = {
    name = "etherion-jwt-secret-prod"
    key  = "latest"
  }
}

# Security Variables - These will be populated by Secret Manager
database_url_secret_name = "etherion-database-url-prod"
secret_key_secret_name   = "etherion-secret-key-prod"
jwt_secret_name          = "etherion-jwt-secret-prod"

# Initial secret data (will be replaced by actual values from Secret Manager)
database_url_secret_data = "postgresql://etherion_user_prod:${var.db_password}@localhost:5432/etherion_prod"
secret_key_secret_data   = "your-actual-prod-secret-key"
jwt_secret_data          = "your-actual-prod-jwt-secret"

# Service Account
service_account_email    = "etherion-sa-prod@your-actual-prod-project-id.iam.gserviceaccount.com"

# Additional Configuration
primary_domain           = "your-domain.com"
dns_zone_name           = "your-dns-zone"
cloud_run_service_name  = "etherion-api-prod"
