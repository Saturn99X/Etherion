{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES2018",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["jest", "node"],
    "typeRoots": ["./types", "./node_modules/@types"],
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@lobechat/const": ["./types/vendor-stubs.d.ts"],
      "@lobechat/model-runtime": ["./vendor/lobechat/model-runtime/index.ts"],
      "@lobechat/types": ["./vendor/lobechat/app-types/index.ts"],
      "@lobechat/utils": ["./vendor/lobechat/shims/utils.ts"],
      "@lobehub/market-sdk": ["./vendor/lobechat/shims/market-sdk.ts"],
      "@lobehub/market-types": ["./vendor/lobechat/shims/market-types.ts"],
      "@lobehub/chat-plugin-sdk": ["./vendor/lobechat/shims/chat-plugin-sdk.ts"],
      "@lobehub/chat-plugin-sdk/lib/types/market": ["./vendor/lobechat/shims/chat-plugin-sdk.ts"],

      "@/features/AgentSetting": ["./types/vendor-stubs.d.ts"],
      "@/features/AgentSetting/*": ["./types/vendor-stubs.d.ts"],
      "@/features/AgentSetting/AgentPlugin": ["./types/vendor-stubs.d.ts"],
      "@/features/AgentPlugin": ["./types/vendor-stubs.d.ts"],
      "@/features/PluginDevModal": ["./types/vendor-stubs.d.ts"],
      "@/features/PluginDevModal/*": ["./types/vendor-stubs.d.ts"],
      "@/features/PluginStore": ["./types/vendor-stubs.d.ts"],
      "@/features/PluginStore/*": ["./types/vendor-stubs.d.ts"],

      "@/components/InfoTooltip": ["./vendor/lobechat/components/InfoTooltip"],
      "@/components/InfoTooltip/*": ["./vendor/lobechat/components/InfoTooltip/*"],
      "@/components/Loading/UpdateLoading": ["./vendor/lobechat/components/Loading/UpdateLoading"],
      "@/components/Loading/UpdateLoading/*": ["./vendor/lobechat/components/Loading/UpdateLoading/*"],
      "@/components/mdx": ["./vendor/lobechat/components/mdx"],
      "@/components/mdx/*": ["./vendor/lobechat/components/mdx/*"],
      "@/components/Menu": ["./vendor/lobechat/components/Menu"],
      "@/components/Menu/*": ["./vendor/lobechat/components/Menu/*"],
      "@/components/Plugins": ["./types/vendor-stubs.d.ts"],
      "@/components/Plugins/*": ["./types/vendor-stubs.d.ts"],
      "@/components/PublishedTime": ["./types/vendor-stubs.d.ts"],
      "@/components/ManifestPreviewer": ["./types/vendor-stubs.d.ts"],
      "@/components/ManifestPreviewer/*": ["./types/vendor-stubs.d.ts"],
      "@/components/InlineTable": ["./types/vendor-stubs.d.ts"],
      "@/components/InlineTable/*": ["./types/vendor-stubs.d.ts"],
      "@/components/KeyValueEditor": ["./types/vendor-stubs.d.ts"],
      "@/components/KeyValueEditor/*": ["./types/vendor-stubs.d.ts"],
      "@/components/MCPStdioCommandInput": ["./types/vendor-stubs.d.ts"],
      "@/components/MCPStdioCommandInput/*": ["./types/vendor-stubs.d.ts"],

      "@/types": ["./vendor/lobechat/app-types"],
      "@/types/*": ["./vendor/lobechat/app-types/*"],

      "@/libs": ["./libs"],
      "@/libs/*": ["./libs/*"],

      "@/const": ["./vendor/lobechat/const"],
      "@/const/*": ["./vendor/lobechat/const/*"],

      "@/features/ModelSelect": ["./types/vendor-stubs.d.ts"],
      "@/features/ModelSwitchPanel": ["./types/vendor-stubs.d.ts"],

      "@/hooks": ["./hooks"],
      "@/hooks/*": ["./hooks/*"],

      "@/styles/electron": ["./vendor/lobechat/styles/electron.ts"],

      "@lobechat/web-crawler": ["./vendor/lobechat/shims/web-crawler.ts"],
      "@lobechat/python-interpreter": ["./vendor/lobechat/shims/python-interpreter.ts"],

      "@/config": ["./vendor/lobechat/config"],
      "@/config/*": ["./vendor/lobechat/config/*"],

      "@/store": ["./types/vendor-stubs.d.ts"],
      "@/store/*": ["./types/vendor-stubs.d.ts"],

      "@/utils/merge": ["./types/vendor-stubs.d.ts"],

      "model-bank": ["./vendor/lobechat/model-bank/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "vendor/lobechat/const/**",
    "./vendor/lobechat/types/src/**",
    "./vendor/lobechat/types/src/discover/**",
    "./vendor/lobechat/shims/**",
    "./vendor/lobechat/features/AgentPlugin/**",
    "vendor/lobechat/features/AgentPlugin/**",
    "vendor/lobechat/**/__tests__/**",
    "vendor/lobechat/**/*.test.ts",
    "vendor/lobechat/**/*.test.tsx",
    "vendor/lobechat/store/**",
    "vendor/lobechat/hooks/**",
    "vendor/lobechat/features/AgentSetting/**",
    "vendor/lobechat/features/PluginStore/**",
    "vendor/lobechat/features/PluginDevModal/**",
    "vendor/lobechat/features/ChatInput/**",
    "vendor/lobechat/features/ModelSelect/**",
    "vendor/lobechat/features/ModelSwitchPanel/**",
    "vendor/lobechat/components/Plugins/**",
    "vendor/lobechat/components/ManifestPreviewer/**",
    "vendor/lobechat/components/InlineTable/**",
    "vendor/lobechat/components/KeyValueEditor/**",
    "vendor/lobechat/components/MCPStdioCommandInput/**",
    "vendor/lobechat/libs/**",
    "vendor/lobechat/services/**",
    "vendor/lobechat/src/**"
  ]
}
