{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": [],
    "paths": {
      "@/database/*": [
        "./packages/database/src/*",
        "./src/database/*"
      ],
      "@/const/*": [
        "./packages/const/src/*",
        "./src/const/*"
      ],
      "@/utils/*": [
        "./packages/utils/src/*",
        "./src/utils/*"
      ],
      "@/types/*": [
        "./packages/types/src/*",
        "./src/types/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "~test-utils": [
        "./tests/utils.tsx"
      ],
      "model-bank": [
        "./vendor/lobechat/model-bank/index.ts"
      ],
      "openai": [
        "./vendor/lobechat/shims/openai.ts"
      ],
      "@etherion/lib/*": [
        "./src/etherion/lib/*"
      ],
      "@etherion/bridge/*": [
        "./src/etherion/bridge/*"
      ],
      "@etherion/stores/*": [
        "./src/etherion/stores/*"
      ],
      "@etherion/components/*": [
        "./src/etherion/components/*"
      ],
      "@etherion/ui/*": [
        "./src/etherion/ui/*"
      ],
      "@etherion/hooks/*": [
        "./src/etherion/hooks/*"
      ],
      "@etherion/vendor/*": [
        "./vendor/lobechat/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "exclude": [
    "node_modules",
    "public/sw.js",
    "apps/desktop",
    "apps/mobile",
    "tmp",
    "temp",
    ".temp",
    "e2e",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "include": [
    "**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next/dev/types/**/*.ts"
  ]
}